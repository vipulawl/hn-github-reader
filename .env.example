# Optional — without this you get 60 GitHub API requests/hour (unauthenticated)
# With a token: 5000/hour. Create one at https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# Required for Reddit tab — create a "script" app at reddit.com/prefs/apps
# Redirect URI can be http://localhost, no scopes needed for public data
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
